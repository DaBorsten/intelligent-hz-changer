{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Intelligent Hz Changer",
  "version": "0.1.0",
  "identifier": "com.daborsten.intelligent-hz-changer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Intelligent Hz Changer",
        "width": 1080,
        "height": 720,
        "visible": false,
        "skipTaskbar": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/DaBorsten/intelligent-hz-changer/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzOEIxRDNENjU5QzY2NEYKUldSUFpweGxQUjJMa3l4bTFiS3UvT1lZTEc4RVRzMXk3L1RFVVUrTTc2eUREQkdxcmhLOWs5ZmIK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}